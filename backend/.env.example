# Database
DATABASE_URL=postgresql://user:password@db:5432/devmatch_db

# JWT & Auth
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# OAuth Token Encryption
OAUTH_TOKEN_ENCRYPTION_KEY=your-32-byte-base64-encoded-key

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# HuggingFace OAuth
HUGGINGFACE_CLIENT_ID=your-huggingface-client-id
HUGGINGFACE_CLIENT_SECRET=your-huggingface-client-secret

# OAuth Callback
OAUTH_CALLBACK_BASE_URL=http://localhost:8000

# CORS Origins (comma-separated or use defaults)
BACKEND_CORS_ORIGINS=["http://localhost:3001", "http://localhost:8000", "*"]
